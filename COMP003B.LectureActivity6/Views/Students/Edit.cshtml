@model COMP003B.LectureActivity6.Models.Student

<h2>Edit Student</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="StudentId" />
    <div>
        <label>Name</label>
        <input asp-for="Name" />
    </div>

    <div>
        <label>Email</label>
        <input asp-for="Email" />
    </div>
    <div>
        <label>Age</label>
        <input asp-for="Age" type="number" />
    </div>
    <button type="submit">Save</button>
</form>

<a asp-action="Index">Back to List</a>